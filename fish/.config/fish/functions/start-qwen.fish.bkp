function start-qwen --description 'Klassischer llama.cpp Start für Qwen3.6-35B-A3B-UD'
    set -l MODEL_PATH "/opt/llama.cpp/models/unsloth/Qwen3.6-35B-A3B-GGUF/Qwen3.6-35B-A3B-UD-Q4_K_M.gguf"

    echo "======================================================================="
    echo "🚀 Starte llama.cpp API-Server für Pi Agent"
    echo "📦 Modell: Qwen3.6-35B-A3B-UD (Klassischer Modus, ohne MTP)"
    echo "======================================================================="
    
    llama-server \
      -m $MODEL_PATH \
      --fit on \
      --fit-ctx 262144 \
      --fit-target 725 \
      -np 1 \
      -fa on \
      --no-mmap \
      --mlock \
      -b 2048 \
      -ub 2048 \
      -ctk q8_0 \
      -ctv q8_0 \
      --temp 0.6 \
      --top-p 0.95 \
      --top-k 20 \
      --min-p 0.0 \
      --presence-penalty 0.0 \
      --repeat-penalty 1.0 \
      --reasoning-budget 1024 \
      --chat-template-kwargs "{\"preserve_thinking\": true}" \
      --host 0.0.0.0 \
      --port 8081 \
      --ctx-checkpoints 256 \
      --context-shift\
      --kv-unified 


end
