# ----------------------------------------------------
# Theme & Colors (GitHub Dark Default)
# ----------------------------------------------------

theme = GitHub Dark Default

#background = #0D1117
#foreground = #c9d1d9
cursor-color = #ced5dc
selection-background = #768bab
selection-foreground = #ced5dc

# ----------------------------------------------------
# Window & Layout 
# ----------------------------------------------------
window-padding-x = 12
window-padding-y = 12
window-width = 100
window-height = 28
window-decoration = false
window-padding-balance = true
window-theme = auto

background-opacity = 0.9
unfocused-split-opacity = 0.3
unfocused-split-fill = #0a0a0a
split-divider-color = #768bab

# ----------------------------------------------------
# Text 
# ----------------------------------------------------
font-family = "JetBrains Mono"
font-size = 13.0
adjust-cell-height = 20%
font-feature = "liga=1,calt=1,ss01=1,ss02=1,ss19=1"

# ----------------------------------------------------
# Maus & Cursor
# ----------------------------------------------------
cursor-style = block
cursor-style-blink = true
mouse-hide-while-typing = true
mouse-shift-capture = false
mouse-scroll-multiplier = 1.0

# ----------------------------------------------------
# macOS Option Key (Alt Key behavior)
# ----------------------------------------------------
macos-option-as-alt = left

# ----------------------------------------------------
# Keybindings 
# ----------------------------------------------------


#keybind = btn3=paste_from_clipboard



# ----------------------------------------------------
# Advanced Terminal Features
# ----------------------------------------------------

link-url = true
clipboard-trim-trailing-spaces = true
copy-on-select = clipboard
click-repeat-interval = 300
focus-follows-mouse = true
shell-integration-features = ssh-env,ssh-terminfo
confirm-close-surface = true
scrollback-limit = 100000